# PostgreSQL
POSTGRES_DB=cryptotrack
POSTGRES_USER=cryptouser
POSTGRES_PASSWORD=cryptopass

# App
DATABASE_URL=postgresql://cryptouser:cryptopass@postgres:5432/cryptotrack
REDIS_URL=redis://redis:6379
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai-hon-32-ky-tu
JWT_EXPIRES_IN=7d
COOKIE_SECRET=thay-bang-chuoi-khac-ngau-nhien

# Email SMTP fallback - Mailpit cho local Docker
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=noreply@cryptotrack.local
SMTP_PASS=
SMTP_FROM=CryptoTrack <noreply@cryptotrack.local>

# Brevo Transactional Email API - uu tien khi co API key, dung cho cloud
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=CoinHub

# External APIs
COINGECKO_API_KEY=
BINANCE_WS_URL=wss://stream.binance.com/stream

# App config
FRONTEND_URL=http://localhost
ADMIN_EMAIL=admin@cryptotrack.com
